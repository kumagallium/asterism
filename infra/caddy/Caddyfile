# Asterism — production reverse proxy / SPA host / session-cookie gate.
#
# A single front for the whole product (the "Private 完結" 1-box bundle):
#   - terminates TLS,
#   - serves the built React SPA (ui/dist, baked into this image at /srv),
#   - reverse-proxies  /api + /jobs -> asterism-api,  /demo -> demo-agent,
#   - gates the WHOLE site behind a SESSION-COOKIE login (the authgate service).
#
# Why a cookie, not HTTP Basic: a session cookie rides on every request — page
# loads, fetch/XHR, SSE — so it never re-prompts, works from anywhere (no VPN),
# on a bare IP, over a self-signed cert. Browser-native Basic auth re-prompts on
# every refresh/navigation in exactly this setup (SPA + self-signed).
#
# TLS is env-driven so the same image works by IP or by domain:
#   ASTERISM_DOMAIN     the host clients use. An IP (e.g. 133.125.93.179) -> a
#                       self-signed cert for that IP; a FQDN (e.g. asterism.e4m.jp)
#                       -> Caddy gets a cert for it. ALWAYS set it (no empty default).
#   ASTERISM_TLS_EMAIL  "internal" (default) -> self-signed local CA (browser warning)
#                       an email (you@e4m.jp) -> Let's Encrypt (real cert; needs a FQDN
#                                                 + DNS A record + ports 80/443 reachable)
#
# Switching from self-signed-by-IP to a real cert later is two env vars, no file edit.
#
# `default_sni` (global) is essential for IP access: a TLS client connecting to a
# bare IP sends NO SNI, so without a default Caddy can't pick the cert and the
# handshake dies with "internal error". It is harmless in FQDN mode (SNI is sent).
#
# The api's own write/design token travels in the X-Asterism-Token header (see
# ui/src/authToken.ts), independent of this gate's cookie.

{
	# Cert to serve when the client sends no SNI (IP access — see header note).
	default_sni {$ASTERISM_DOMAIN}
}

https://{$ASTERISM_DOMAIN} {
	tls {$ASTERISM_TLS_EMAIL:internal}

	log {
		output stdout
		format console
	}

	encode gzip zstd

	# The login gate's own endpoints (login form, verify, logout) are PUBLIC — they
	# must be reachable without a session, or login itself would be locked out.
	handle /__auth/* {
		reverse_proxy authgate:9000
	}

	# Everything else requires a valid session cookie. `route` keeps the order
	# explicit: forward_auth runs FIRST — it calls the gate's /__auth/verify with the
	# request's Cookie; 2xx -> the request falls through to the routing below; a 302
	# (no/expired cookie) is returned straight to the browser, sending it to login.
	handle {
		route {
			forward_auth authgate:9000 {
				uri /__auth/verify
			}

			# Workbench API + the (no-/api-prefix) ingest-history endpoint.
			# The cookie gate above IS the access control. caddy vouches for an
			# authenticated request by injecting the api's write token, so the
			# operator never has to paste it into the UI. `header_up` SETS (replaces)
			# the header, so a logged-in client can't spoof a different token.
			@api path /api/* /jobs /jobs/*
			reverse_proxy @api api:8080 {
				header_up X-Asterism-Token {$ASTERISM_API_TOKEN}
			}

			# IRI dereference (ADR instance-iri-base.md phase 2). When
			# ASTERISM_IRI_BASE is https://<this domain>, the IRIs this install
			# mints live under /datasets/* on THIS host — resolve them via the
			# api's content-negotiated /describe (Turtle for machines, HTML for
			# humans; published/canonical data only, no token needed). /describe
			# itself is routed too so the HTML view's follow-links work.
			# NOTE: sits inside the session gate like everything else — citation
			# links resolve for logged-in users. To make dereference PUBLIC
			# (anonymous citation links), move these lines into their own
			# `handle /datasets/* { … }` block next to /__auth/* above.
			@iri path /datasets/*
			handle @iri {
				rewrite * /describe?iri=https://{$ASTERISM_DOMAIN}{path}
				reverse_proxy api:8080
			}
			reverse_proxy /describe api:8080

			# Grounded-answer (Ask) service.
			reverse_proxy /demo/* demo-agent:8090

			# Everything else: the SPA. Client-side routing falls back to index.html.
			root * /srv
			try_files {path} /index.html
			file_server
		}
	}
}
