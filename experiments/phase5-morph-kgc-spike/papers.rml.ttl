# Phase 5 spike — declarative CSV->RDF for starrydata papers via RML (no codegen).
# Goal: prove the "no generated Python" path (option 2 in ingestion-execution-safety.md)
# produces the same sd:Paper triples as the procedural ingester, for the simple
# columns. Transforms that need a *closed* function library (FnO) are noted in
# README and deliberately NOT mapped here (issued->xsd:date, author JSON->Person,
# composite IRIs for sample/curve, QUDT lookup, IRI sanitize).
@prefix rr:      <http://www.w3.org/ns/r2rml#> .
@prefix rml:     <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:      <http://semweb.mmlab.be/ns/ql#> .
@prefix sd:      <https://kumagallium.github.io/csv2rdf-mcp/starrydata/ontology#> .
@prefix schema:  <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<#PaperMap> a rr:TriplesMap ;
  rml:logicalSource [
    rml:source "papers.csv" ;
    rml:referenceFormulation ql:CSV
  ] ;
  rr:subjectMap [
    rr:template "https://kumagallium.github.io/csv2rdf-mcp/starrydata/resource/paper/{SID}" ;
    rr:class sd:Paper
  ] ;
  rr:predicateObjectMap [
    rr:predicate schema:name ;
    rr:objectMap [ rml:reference "title" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate dcterms:identifier ;
    rr:objectMap [ rml:reference "DOI" ]
  ] .
