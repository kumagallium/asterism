@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#> .
@prefix fno: <https://w3id.org/function/ontology#> .
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#> .
@prefix sd: <http://localhost/asterism/starrydata/ontology#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# Phase 0.5 — JSON 埋め込み列 (issued) を FnO で展開する試み
#
# RML/Morph-KGC は logical source レベルでは reference formulation を 1 つしか
# 持てないため、CSV の中にあるセル内 JSON をネスト iterate するには:
#   - FnO 経由で json-parse / json-path を呼ぶ
#   - その結果を rr:objectMap の term map に当てる
# という流れになる。
#
# 以下は "issued" 列から年だけを取り出して xsd:gYear にする例。
# Morph-KGC の FnO サポートは partial (idlab-fn の一部のみ) で、
# grel:controls_if などはサポートされても任意の Python eval は許されない。
# ============================================================

<#PapersSource>
    rml:source "data/papers_100.csv" ;
    rml:referenceFormulation ql:CSV .

# issued -> year (substring approach, fragile but FnO-safe)
# starrydata の issued は {"date_parts":[[YYYY,MM,DD]]} 形式。
# JSON parse 経由が理想だが、ここでは固定位置 substring に頼った fragile な例を示す。
# 具体的には: issued[16:20] が 4-digit year に相当 (引用符 + フィールド名スキップ)。
<#PaperYearMap>
    rml:logicalSource <#PapersSource> ;
    rr:subjectMap [
        rr:template "http://localhost/asterism/starrydata/resource/paper/{SID}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:datePublished ;
        rr:objectMap [
            fnml:functionValue [
                rml:logicalSource <#PapersSource> ;
                rr:predicateObjectMap [
                    rr:predicate fno:executes ;
                    rr:objectMap [ rr:constant grel:string_substring ]
                ] ;
                rr:predicateObjectMap [
                    rr:predicate grel:valueParameter ;
                    rr:objectMap [ rml:reference "issued" ]
                ] ;
                rr:predicateObjectMap [
                    rr:predicate grel:p_int_i_from ;
                    rr:objectMap [ rr:constant "16" ; rr:datatype xsd:integer ]
                ] ;
                rr:predicateObjectMap [
                    rr:predicate grel:p_int_i_opt_to ;
                    rr:objectMap [ rr:constant "20" ; rr:datatype xsd:integer ]
                ]
            ] ;
            rr:datatype xsd:gYear
        ]
    ] .
