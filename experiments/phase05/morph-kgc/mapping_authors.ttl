@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix sd: <http://localhost/csv2rdf/starrydata/ontology#> .
@prefix schema: <https://schema.org/> .

# 前処理で authors.jsonl を生成しておく前提。
# papers_100.csv -> preprocess_to_json.py -> authors.jsonl (1 author = 1 行)
# 各行: {"sid": "...", "idx": 0, "given": "...", "family": "..."}

<#AuthorSource>
    rml:source "data/authors.json" ;
    rml:referenceFormulation ql:JSONPath ;
    rml:iterator "$[*]" .

<#PersonMap>
    rml:logicalSource <#AuthorSource> ;
    rr:subjectMap [
        rr:template "http://localhost/csv2rdf/starrydata/resource/person/{sid}/{idx}" ;
        rr:class schema:Person
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:givenName ;
        rr:objectMap [ rml:reference "given" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:familyName ;
        rr:objectMap [ rml:reference "family" ]
    ] .

<#PaperAuthorLink>
    rml:logicalSource <#AuthorSource> ;
    rr:subjectMap [
        rr:template "http://localhost/csv2rdf/starrydata/resource/paper/{sid}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:author ;
        rr:objectMap [
            rr:template "http://localhost/csv2rdf/starrydata/resource/person/{sid}/{idx}" ;
            rr:termType rr:IRI
        ]
    ] .
