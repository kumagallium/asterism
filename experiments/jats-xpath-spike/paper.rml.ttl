# Spike: JATS (XML) -> doco/nif/fabio via the Asterism substrate (ql:XPath).
# PROVEN with morph-kgc 2.10 (see README.md).
#
# morph-kgc XML references are iterator-RELATIVE only — no absolute paths, no
# parent/ancestor axes, and every template must carry at least one {ref}. So:
#   * the article IRI is derived where the article-id is reachable (the /article
#     iterator), and
#   * the sec/para maps (whose iterators sit at /sec and /p) cannot reach the
#     ancestor article-id, so the paper-id base is a per-paper constant ("SID-6").
#     In production, inject that base per source file (the ingest is per-paper).
# Containment is built parent->child via a MULTI-VALUED child reference
# ({body/sec/@id}, {p/@id}); a child->parent axis template ({parent::sec/@id})
# is rejected by morph-kgc's template parser.
@prefix rr:    <http://www.w3.org/ns/r2rml#> .
@prefix rml:   <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:    <http://semweb.mmlab.be/ns/ql#> .
@prefix fabio: <http://purl.org/spar/fabio/> .
@prefix doco:  <http://purl.org/spar/doco/> .
@prefix po:    <http://www.essepuntato.it/2008/12/pattern#> .
@prefix nif:   <http://persistence.uni-leipzig.de/nlp2rdf/ontologies/nif-core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .

<#ArticleMap> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "paper.xml" ; rml:referenceFormulation ql:XPath ; rml:iterator "/article" ] ;
  rr:subjectMap [ rr:template "https://ex/paper/{front/article-meta/article-id}" ;
    rr:class fabio:ResearchPaper, prov:Entity ] ;
  # article -> section containment (two relative refs from /article; sec id is multi-valued)
  rr:predicateObjectMap [ rr:predicate po:contains ;
    rr:objectMap [ rr:template "https://ex/paper/{front/article-meta/article-id}/sec/{body/sec/@id}" ; rr:termType rr:IRI ] ] .

<#SecMap> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "paper.xml" ; rml:referenceFormulation ql:XPath ; rml:iterator "/article/body/sec" ] ;
  rr:subjectMap [ rr:template "https://ex/paper/SID-6/sec/{@id}" ; rr:class doco:Section ] ;
  rr:predicateObjectMap [ rr:predicate dcterms:title ; rr:objectMap [ rml:reference "title" ] ] ;
  # section -> paragraph containment (multi-valued child reference, no axis)
  rr:predicateObjectMap [ rr:predicate po:contains ;
    rr:objectMap [ rr:template "https://ex/paper/SID-6/para/{p/@id}" ; rr:termType rr:IRI ] ] .

<#ParaMap> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "paper.xml" ; rml:referenceFormulation ql:XPath ; rml:iterator "/article/body/sec/p" ] ;
  rr:subjectMap [ rr:template "https://ex/paper/SID-6/para/{@id}" ; rr:class doco:Paragraph ] ;
  rr:predicateObjectMap [ rr:predicate nif:isString ; rr:objectMap [ rml:reference "." ] ] .
