sd:PointDefect a owl:Class ;
    rdfs:label "Point Defect"@en,
        "点欠陥"@ja ;
    rdfs:comment "A point defect (substitutional dopant / interstitial / vacancy) that represents the deviation of a real sample from its idealized host structure. Doping is modeled here as point defects."@en ;
    rdfs:seeAlso <https://atomrdf.pyscal.org/> ;
    rdfs:subClassOf prov:Entity .

<https://github.com/kumagallium/asterism#mp-linking-poc> a prov:SoftwareAgent ;
    schema:name "asterism mp-linking PoC" .

sd:StructureMatchActivity a owl:Class ;
    rdfs:label "Structure Match Activity"@en,
        "構造突き合わせアクティビティ"@ja ;
    rdfs:comment "The act of resolving a sample's host phase to an idealized crystal structure (e.g. by composition normalization + Materials Project lookup). Carries method, confidence, and the MP functional so the link is auditable. Mirrors sd:IngestionActivity / sd:DigitizationActivity."@en ;
    rdfs:subClassOf prov:Activity .

