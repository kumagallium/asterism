@prefix mp: <https://next-gen.materialsproject.org/materials/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sd: <https://kumagallium.github.io/asterism/starrydata/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sd:crystalSystem a owl:DatatypeProperty ;
    rdfs:label "crystal system"@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:string .

sd:dopantElement a owl:DatatypeProperty ;
    rdfs:label "dopant element"@en ;
    rdfs:domain sd:PointDefect ;
    rdfs:range xsd:string .

sd:hasHostStructure a owl:ObjectProperty ;
    rdfs:label "has host structure"@en,
        "母相構造を持つ"@ja ;
    rdfs:comment "Links a Sample to the idealized CrystalStructure of its host (parent) phase. Weak link: the sample is doped / non-stoichiometric, the structure is the pristine parent."@en ;
    rdfs:domain sd:Sample ;
    rdfs:range sd:CrystalStructure .

sd:hasPointDefect a owl:ObjectProperty ;
    rdfs:label "has point defect"@en,
        "点欠陥を持つ"@ja ;
    rdfs:domain sd:Sample ;
    rdfs:range sd:PointDefect .

sd:idealizedFrom a owl:ObjectProperty ;
    rdfs:label "idealized from"@en,
        "理想化の出所"@ja ;
    rdfs:comment "The computational database entry (e.g. a Materials Project material IRI) this idealized structure was taken from. Deliberately a sub-property of prov:wasDerivedFrom, NOT owl:sameAs: the sample is not identical to the computed compound."@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:seeAlso <https://optimade.materialsproject.org/> ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

sd:matchConfidence a owl:DatatypeProperty ;
    rdfs:label "match confidence"@en ;
    rdfs:comment "high / medium / unresolved. 'unresolved' attempts are emitted too, so coverage gaps stay queryable."@en ;
    rdfs:domain sd:StructureMatchActivity ;
    rdfs:range xsd:string .

sd:matchMethod a owl:DatatypeProperty ;
    rdfs:label "match method"@en ;
    rdfs:comment "How the host was resolved, e.g. \"MaterialFamily(curator) + composition diff\", \"composition-normalization\"."@en ;
    rdfs:domain sd:StructureMatchActivity ;
    rdfs:range xsd:string .

sd:mpFunctional a owl:DatatypeProperty ;
    rdfs:label "MP functional"@en ;
    rdfs:comment "DFT functional behind the MP entry (e.g. \"GGA/GGA+U\", \"r2SCAN\"), or \"demo\" for the placeholder PoC table."@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:string .

sd:reducedHostFormula a owl:DatatypeProperty ;
    rdfs:label "reduced host formula"@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:string .

sd:siteAmount a owl:DatatypeProperty ;
    rdfs:label "site amount (per formula)"@en ;
    rdfs:comment "Amount of the dopant as written in the sample's composition formula (per-formula-unit, not normalized)."@en ;
    rdfs:domain sd:PointDefect ;
    rdfs:range xsd:double .

sd:solidSolutionElement a owl:DatatypeProperty ;
    rdfs:label "solid solution element"@en ;
    rdfs:comment "A non-dilute substituent sharing a site in the host (e.g. Se in Bi2(Te,Se)3)."@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:string .

sd:spaceGroupNumber a owl:DatatypeProperty ;
    rdfs:label "space group number"@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:integer .

sd:spaceGroupSymbol a owl:DatatypeProperty ;
    rdfs:label "space group symbol"@en ;
    rdfs:comment "Hermann-Mauguin symbol, e.g. \"Fm-3m\", \"R-3m\"."@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:string .

sd:structurePrototype a owl:DatatypeProperty ;
    rdfs:label "structure prototype"@en ;
    rdfs:comment "Structure type / prototype, e.g. \"rock salt (NaCl-type)\", \"tetradymite (Bi2Te3-type)\". More robust to doping than an exact mp-id."@en ;
    rdfs:domain sd:CrystalStructure ;
    rdfs:range xsd:string .

