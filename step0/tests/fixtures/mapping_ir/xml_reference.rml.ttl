# Handwritten XML/XPath reference for the compiler golden test — mirrors the
# document-ontology patterns of datasets/papers/jats/PMC5951533.rml.ttl:
# constant per-document subject, XPath iterator, attribute references, a child
# multi-valued po:contains link and a Tier-0 function objectMap.
@prefix rr:      <http://www.w3.org/ns/r2rml#> .
@prefix rml:     <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:      <http://semweb.mmlab.be/ns/ql#> .
@prefix rmlf:    <http://w3id.org/rml/> .
@prefix fn:      <https://kumagallium.github.io/asterism/fn/> .
@prefix doco:    <http://purl.org/spar/doco/> .
@prefix po:      <http://www.essepuntato.it/2008/12/pattern#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lit:     <https://example.org/papers/ontology#> .

<#PaperMap> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "doc.xml" ; rml:referenceFormulation ql:XPath ;
                      rml:iterator "/article" ] ;
  rr:subjectMap [ rr:constant <https://example.org/papers/resource/paper/P1> ;
    rr:class lit:Paper ] ;
  rr:predicateObjectMap [ rr:predicate dcterms:identifier ;
    rr:objectMap [ rr:constant "10.1234/x" ] ] ;
  rr:predicateObjectMap [ rr:predicate po:contains ;
    rr:objectMap [ rr:template "https://example.org/papers/resource/paper/P1/sec/{body/sec/@id}" ;
      rr:termType rr:IRI ] ] .

<#SectionMap> a rr:TriplesMap ;
  rml:logicalSource [ rml:source "doc.xml" ; rml:referenceFormulation ql:XPath ;
                      rml:iterator "/article/body//sec" ] ;
  rr:subjectMap [ rr:template "https://example.org/papers/resource/paper/P1/sec/{@id}" ;
    rr:class doco:Section ] ;
  rr:predicateObjectMap [ rr:predicate dcterms:title ;
    rr:objectMap [ rml:reference "title" ] ] ;
  rr:predicateObjectMap [ rr:predicate lit:structuralPath ;
    rr:objectMap [ rmlf:functionExecution [ rmlf:function fn:structural_slug ;
      rmlf:input [ rmlf:parameter fn:p_value ;
                   rmlf:inputValueMap [ rml:reference "title" ] ] ] ] ] .
