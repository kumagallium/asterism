# asterism local compose overrides.
#
# Copy to `.env` (gitignored) and adjust per machine. Docker Compose loads
# `.env` automatically.

# Host port published for the upload-api service. The container always listens
# on 8080; only the host-side mapping changes. Set this when 8080 is already
# taken on the host (e.g. a running Crucible occupies 8080).
#   CSV2RDF_UPLOAD_API_PORT=8082
CSV2RDF_UPLOAD_API_PORT=8080

# --- Security (safe-by-default) ---------------------------------------------
#
# Shared secret gating the WRITE / DESIGN / raw-SPARQL api routes (upload,
# materialize, ingest, promote, retract, reinstate, delete, tools-write,
# /api/sparql). When UNSET those routes FAIL CLOSED (503): a sensitive store is
# never mutated or root-read anonymously. Set it to enable writes; present it as
# `Authorization: Bearer <token>` or `X-Asterism-Token: <token>` (the UI reads it
# from VITE_API_TOKEN / sessionStorage). Use a long random value in production.
#   ASTERISM_API_TOKEN=$(openssl rand -hex 32)

# Arbitrary read-only SPARQL escape (MCP sparql_query, /api/sparql, /demo/sparql).
# DEFAULT OFF (typed tools only). Set to 1 only on a deployment that should expose
# the raw escape (e.g. a co-located local demo over non-sensitive data).
#   ASTERISM_EXPOSE_RAW_SPARQL=1

# demo-agent CORS allowlist (comma-separated origins permitted to read responses
# cross-origin). Defaults to the local Vite dev origins. Never use "*".
#   ASTERISM_DEMO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Hard cap on a single uploaded file, in bytes (disk-fill / OOM guard). Default
# 1 GiB; set 0 to disable. The cap is enforced on bytes actually read, not on the
# (untrusted) Content-Length.
#   ASTERISM_MAX_UPLOAD_BYTES=1073741824
