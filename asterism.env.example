# Asterism production config — copy to `asterism.env` and fill in.
#   cp asterism.env.example asterism.env
# `asterism.env` is gitignored and is injected into containers via `env_file`
# (NOT Compose ${}-substitution), so a bcrypt hash with `$` is passed literally.
# Do NOT commit asterism.env.

# ─── Domain / TLS (Caddy) ────────────────────────────────────────────────────
# Empty -> Caddy serves HTTPS on :443 with a self-signed local CA (browser
# warning; fine for a private box). Set to a real FQDN to bind that host name.
ASTERISM_DOMAIN=

# "internal" -> self-signed local CA. An email -> Let's Encrypt (REQUIRES a real
# ASTERISM_DOMAIN with a DNS A record pointing here and ports 80/443 reachable).
#   e.g. when you have asterism.e4m.jp:  ASTERISM_DOMAIN=asterism.e4m.jp
#                                        ASTERISM_TLS_EMAIL=you@e4m.jp
ASTERISM_TLS_EMAIL=internal

# ─── Whole-site gate (Caddy Basic auth) ──────────────────────────────────────
ASTERISM_BASIC_AUTH_USER=asterism
# Generate the hash (note the literal $ are fine here — env_file passes verbatim):
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOURPASS'
ASTERISM_BASIC_AUTH_HASH=

# ─── API write/design token (api) ────────────────────────────────────────────
# Gates write / design / raw-SPARQL routes (sent by the SPA as X-Asterism-Token).
# Unset -> those routes are DISABLED (503). Use a long random secret WITHOUT '$'
# (e.g. `openssl rand -hex 32`) so nothing downstream tries to interpolate it.
ASTERISM_API_TOKEN=

# ─── Ask CORS (demo-agent) ───────────────────────────────────────────────────
# Same-origin via Caddy, so usually leave blank. If you call /demo from another
# origin, set it to that origin (e.g. https://asterism.e4m.jp).
ASTERISM_DEMO_CORS_ORIGINS=
