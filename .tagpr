# tagpr 設定 — https://github.com/Songmu/tagpr
# Graphium(provnote) の運用に倣う。asterism は Python マルチパッケージなので、
# versionFile はルートの VERSION（単一の真実源）。Tauri 固有の command は付けない。
[tagpr]
versionFile = VERSION
releaseBranch = main
vPrefix = true
changelog = true
# Version bump is decided per merged PR via labels (default is patch). Apply the
# "minor" label to a feature/breaking PR to bump the minor version; "major" for major.
majorLabels = ["major"]
minorLabels = ["minor"]
